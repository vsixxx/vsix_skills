{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openai.local/investment-banking/model_citations.schema.json",
  "title": "Investment Banking Model Citations",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "citation_id",
      "workbook_path",
      "sheet",
      "cell_or_range",
      "metric_name",
      "value",
      "formula",
      "source_ids",
      "assumption_flag",
      "tie_out_status"
    ],
    "additionalProperties": true,
    "properties": {
      "citation_id": {
        "type": "string",
        "minLength": 1
      },
      "id": {
        "type": "string"
      },
      "source_id": {
        "type": "string"
      },
      "workbook_path": {
        "type": "string",
        "minLength": 1
      },
      "sheet": {
        "type": "string",
        "minLength": 1
      },
      "cell_or_range": {
        "type": "string",
        "minLength": 1
      },
      "cell": {
        "type": "string"
      },
      "range": {
        "type": "string"
      },
      "metric_name": {
        "type": "string",
        "minLength": 1
      },
      "value": {
        "type": "string"
      },
      "formula": {
        "type": "string"
      },
      "source_ids": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string"
        }
      },
      "assumption_flag": {
        "type": "boolean"
      },
      "tie_out_status": {
        "type": "string",
        "enum": [
          "tied",
          "not_tied",
          "needs_review",
          "model_generated",
          "not_applicable"
        ]
      }
    }
  }
}
