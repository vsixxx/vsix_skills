{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openai.local/investment-banking/plugin_routing_map.schema.json",
  "title": "Investment Banking Plugin Routing Map",
  "type": "object",
  "required": [
    "version",
    "plugin",
    "routing_policy",
    "workflows"
  ],
  "additionalProperties": true,
  "properties": {
    "version": {
      "const": "1.0"
    },
    "plugin": {
      "const": "investment-banking"
    },
    "routing_policy": {
      "type": "object",
      "required": [
        "playbook_reference",
        "default_routing_principle",
        "artifact_hierarchy",
        "handoff_validation",
        "support_artifact_policy"
      ],
      "additionalProperties": true,
      "properties": {
        "playbook_reference": {"type": "string"},
        "default_routing_principle": {"type": "string"},
        "artifact_hierarchy": {"type": "string"},
        "handoff_validation": {"type": "string"},
        "support_artifact_policy": {"type": "string"}
      }
    },
    "workflows": {
      "type": "array",
      "minItems": 10,
      "items": {"$ref": "#/$defs/workflow"}
    }
  },
  "$defs": {
    "workflow": {
      "type": "object",
      "required": [
        "workflow_id",
        "workflow_name",
        "banker_intent",
        "typical_user_prompts",
        "lead_skill",
        "supporting_skills",
        "handoff_contracts",
        "default_artifact_mode",
        "hero_deliverable",
        "companion_deliverables",
        "support_artifacts",
        "source_gates",
        "quality_gates",
        "routing_triggers",
        "do_not_route_when",
        "escalation_paths",
        "clarifying_questions",
        "stop_or_escalate_when"
      ],
      "additionalProperties": true,
      "properties": {
        "workflow_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "workflow_name": {"type": "string", "minLength": 1},
        "banker_intent": {"type": "string", "minLength": 1},
        "typical_user_prompts": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "lead_skill": {"type": "string", "minLength": 1},
        "supporting_skills": {"type": "array", "items": {"type": "string"}},
        "handoff_contracts": {"type": "array", "items": {"$ref": "#/$defs/handoff_contract"}},
        "default_artifact_mode": {
          "type": "string",
          "enum": [
            "workbook",
            "html_report",
            "html_dashboard",
            "native_deck",
            "native_document",
            "generated_package",
            "hybrid",
            "chat_only"
          ]
        },
        "hero_deliverable": {"type": "string", "minLength": 1},
        "companion_deliverables": {"type": "array", "items": {"type": "string"}},
        "support_artifacts": {"type": "array", "items": {"type": "string"}},
        "source_gates": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "quality_gates": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "routing_triggers": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "do_not_route_when": {"type": "array", "items": {"type": "string"}},
        "escalation_paths": {"type": "array", "items": {"$ref": "#/$defs/escalation_path"}},
        "clarifying_questions": {"type": "array", "items": {"type": "string"}},
        "stop_or_escalate_when": {"type": "array", "items": {"type": "string"}}
      }
    },
    "handoff_contract": {
      "type": "object",
      "required": ["contract_name", "producer_skill", "consumer_skill", "required_when"],
      "additionalProperties": true,
      "properties": {
        "contract_name": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "producer_skill": {"type": "string"},
        "consumer_skill": {"type": "string"},
        "required_when": {"type": "string"}
      }
    },
    "escalation_path": {
      "type": "object",
      "required": ["to", "when"],
      "additionalProperties": true,
      "properties": {
        "to": {"type": "string"},
        "when": {"type": "string"}
      }
    }
  }
}
