# PPT Master does not require an image-provider API key.
# It uses the current agent's native image tool or an installed image Skill.

# Optional web image search providers. Openverse and Wikimedia need no key.
# PEXELS_API_KEY=
# PIXABAY_API_KEY=

# Optional cloud narration providers. The default edge-tts path needs no key.
# ELEVENLABS_API_KEY=
# MINIMAX_API_KEY=
# QWEN_API_KEY=
# COSYVOICE_API_KEY=
# DASHSCOPE_API_KEY=
