{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "investment-banking/schemas/cim_teardown_to_memo_builder.schema.json",
  "title": "cim_teardown_to_memo_builder",
  "description": "Canonical Investment Banking handoff contract from cim-teardown to memo-builder.",
  "type": "object",
  "required": [
    "contract_name"
  ],
  "properties": {
    "contract_name": {
      "const": "cim_teardown_to_memo_builder"
    }
  },
  "additionalProperties": true,
  "$defs": {
    "record": {
      "type": "object",
      "required": [
        "transaction_context",
        "asset_type",
        "source_scope",
        "source_as_of_dates",
        "ic_60_second_view",
        "top_claims",
        "material_red_flags",
        "underwriting_implications",
        "diligence_questions",
        "seller_data_requests",
        "open_evidence_gaps",
        "management_follow_ups",
        "risk_mitigants",
        "recommended_next_step",
        "circulation_caveats"
      ],
      "properties": {
        "transaction_context": {
          "type": [
            "string",
            "number",
            "boolean",
            "array",
            "object"
          ]
        },
        "asset_type": {
          "type": [
            "string",
            "number",
            "boolean",
            "array",
            "object"
          ]
        },
        "source_scope": {
          "type": [
            "string",
            "number",
            "boolean",
            "array",
            "object"
          ]
        },
        "source_as_of_dates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "handoff_common.schema.json#/$defs/generic_record"
          }
        },
        "ic_60_second_view": {
          "type": [
            "string",
            "number",
            "boolean",
            "array",
            "object"
          ]
        },
        "top_claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "handoff_common.schema.json#/$defs/generic_record"
          }
        },
        "material_red_flags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "handoff_common.schema.json#/$defs/generic_record"
          }
        },
        "underwriting_implications": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "handoff_common.schema.json#/$defs/generic_record"
          }
        },
        "diligence_questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "handoff_common.schema.json#/$defs/generic_record"
          }
        },
        "seller_data_requests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "handoff_common.schema.json#/$defs/generic_record"
          }
        },
        "open_evidence_gaps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "handoff_common.schema.json#/$defs/generic_record"
          }
        },
        "management_follow_ups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "handoff_common.schema.json#/$defs/generic_record"
          }
        },
        "risk_mitigants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "handoff_common.schema.json#/$defs/generic_record"
          }
        },
        "recommended_next_step": {
          "type": [
            "string",
            "number",
            "boolean",
            "array",
            "object"
          ]
        },
        "circulation_caveats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "handoff_common.schema.json#/$defs/circulation_caveat"
          }
        }
      },
      "additionalProperties": true
    }
  }
}
